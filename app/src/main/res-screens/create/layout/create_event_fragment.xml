<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/create_event_frag"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:theme="@style/Theme.Material3.Dark.NoActionBar">

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/create_event_allDay_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:checked="false"
        android:text="All-day"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/create_event_startDate_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@+id/create_event_allDay_button">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_event_startDate_button"
            style="@style/Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:text="Sun, Feb 1, 2026" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_event_startTime_button"
            style="@style/Button"
            android:text="20:00"
            android:layout_gravity="end"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/create_event_endDate_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@+id/create_event_startDate_container">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_event_endDate_button"
            style="@style/Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:text="Mon, Feb 2, 2026" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_event_endTime_button"
            android:text="20:00"
            style="@style/Button"
            android:layout_width="0dp"
            android:visibility="gone"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

    </LinearLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_event_repeat_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Does not repeat"
        app:layout_constraintTop_toBottomOf="@+id/create_event_endDate_container" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/create_event_description_edit_text"
        android:textColor="@color/black"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Add description"
        app:counterEnabled="true"
        app:counterMaxLength="8192"
        app:layout_constraintTop_toBottomOf="@+id/create_event_repeat_button" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_event_description_edit_text" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/create_event_notification_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/create_event_description_edit_text"
        tools:itemCount="5"
        tools:listitem="@layout/create_notification_item" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_event_notification_list" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/create_event_set_color_rv"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:clipToPadding="false"
        android:paddingStart="160dp"
        android:paddingEnd="160dp"
        app:layout_constraintTop_toBottomOf="@+id/create_event_notification_list" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_event_set_color_rv" />

</androidx.constraintlayout.widget.ConstraintLayout>