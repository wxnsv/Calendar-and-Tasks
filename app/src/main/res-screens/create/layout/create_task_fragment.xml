<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/create_task_frag"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_task_deadline_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_deadline"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_task_deadline_button" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/create_task_description_edit_text"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/add_description"
        app:counterEnabled="true"
        app:counterMaxLength="8192"
        app:layout_constraintTop_toBottomOf="@+id/create_task_deadline_button" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_task_description_edit_text" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_task_set_list_button"
        style="@style/Button"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/my_tasks"
        app:layout_constraintTop_toBottomOf="@+id/create_task_description_edit_text" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_task_set_list_button" />

</androidx.constraintlayout.widget.ConstraintLayout>