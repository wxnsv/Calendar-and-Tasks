<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:theme="@style/Theme.Material3.Dark.NoActionBar">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_birthday_date_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Jan 27"
        app:icon="@drawable/editor_birthday_date"
        app:iconTint="@color/black"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_birthday_date_button" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/create_birthday_notification_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:overScrollMode="never"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/create_birthday_date_button"
        tools:itemCount="5"
        tools:layout_editor_absoluteX="0dp"
        tools:listitem="@layout/create_notification_item" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_birthday_notification_button"
        style="@style/Button"
        app:iconSize="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add notification"
        app:layout_constraintTop_toBottomOf="@+id/create_birthday_notification_list" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_birthday_notification_button" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/create_birthday_set_color_rv"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:clipToPadding="false"
        android:paddingStart="160dp"
        android:paddingEnd="160dp"
        app:layout_constraintTop_toBottomOf="@+id/create_birthday_notification_button" />
</androidx.constraintlayout.widget.ConstraintLayout>