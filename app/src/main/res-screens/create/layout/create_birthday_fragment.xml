<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_birthday_date_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/jan_27"
        android:textColor="?attr/colorOnSurface"
        app:icon="@drawable/birthday"
        app:iconTint="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/view2"
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_birthday_date_button" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/create_birthday_set_color_tv"
        android:layout_marginTop="10dp"
        android:layout_marginHorizontal="10dp"
        android:layout_width="match_parent"
        android:textColor="?attr/colorOnSurface"
        android:fontFamily="@font/inter_regular"
        android:textSize="16sp"
        android:layout_height="wrap_content"
        android:text="@string/set_color"
        app:layout_constraintTop_toBottomOf="@+id/create_birthday_date_button" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/create_birthday_set_color_rv"
        android:layout_width="match_parent"
        android:layout_marginTop="5dp"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/create_birthday_set_color_tv" />

    <View
        style="@style/Divider"
        android:layout_marginTop="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_birthday_set_color_rv" />
</androidx.constraintlayout.widget.ConstraintLayout>