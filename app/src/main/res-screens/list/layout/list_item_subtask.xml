<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="75dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:id="@+id/list_item"
    android:paddingStart="50dp">

    <FrameLayout
        android:id="@+id/list_subtask_checkbox_container"
        android:layout_width="54dp"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/list_subtask_checkbox"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="15dp"
            android:button="@drawable/checkbox_round_selector"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:useMaterialThemeColors="false"
            app:buttonTint="@null"
            android:checked="false" />
    </FrameLayout>

    <TextView
        android:id="@+id/list_subtask_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:textSize="15sp"
        android:text="@string/item_text_sample"
        app:layout_constraintStart_toEndOf="@+id/list_subtask_checkbox_container"
        app:layout_constraintTop_toTopOf="parent" />

    <!--    <TextView-->
    <!--        android:id="@+id/item_timestamp"-->
    <!--        android:layout_width="wrap_content"-->
    <!--        android:layout_height="wrap_content"-->
    <!--        android:layout_marginStart="10dp"-->
    <!--        android:layout_marginTop="10dp"-->
    <!--        android:text="@string/today"-->
    <!--        android:textSize="15sp"-->
    <!--        app:layout_constraintStart_toEndOf="@+id/list_subtask_checkbox_container"-->
    <!--        app:layout_constraintTop_toBottomOf="@+id/list_subtask_title" />-->
</androidx.constraintlayout.widget.ConstraintLayout>