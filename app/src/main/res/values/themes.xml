<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Calendar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="android:colorBackgroundFloating">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>

        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorSurfaceContainer">@color/md_theme_light_surfaceContainer</item>

        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>

        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>

        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        s
        <item name="android:fontFamily">@font/app_font</item>
        <item name="fontFamily">@font/app_font</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1D788F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_svg</item>

        <item name="postSplashScreenTheme">@style/Theme.Calendar</item>
    </style>

    <style name="ThemeOverlay.App.DatePicker" parent="ThemeOverlay.MaterialComponents.MaterialCalendar" />

    <style name="ShapeAppearance.App.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">?attr/colorOutline</item>
    </style>

    <style name="Button" parent="Widget.MaterialComponents.Button.TextButton.Icon">
        <item name="textAllCaps">false</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="elevation">0dp</item>
        <item name="android:gravity">start</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:contentInsetStart">0dp</item>
        <item name="android:contentInsetEnd">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingStart">45dp</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">12dp</item>
    </style>
</resources>