<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/create_task_frag"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.Material3.Dark.NoActionBar">

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/create_task_allDay_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:checked="false"
        android:text="All-day"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:id="@+id/create_task_set_date_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@+id/create_task_allDay_button">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_task_set_date_button"
            style="@style/Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Sun, Feb 1 2026"
            app:layout_constraintTop_toBottomOf="@+id/create_task_allDay_button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_task_set_time_button"
            style="@style/Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_weight="1"
            android:text="20:00" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_task_deadline_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add deadline"
        app:layout_constraintTop_toBottomOf="@+id/create_task_set_date_container" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_task_deadline_button" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_task_repeat_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Does not repeat"
        app:layout_constraintTop_toBottomOf="@+id/create_task_deadline_button" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_task_deadline_button" />


    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/create_task_details_edit_text"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Add details"
        app:layout_constraintTop_toBottomOf="@+id/create_task_deadline_button" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_task_details_edit_text" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/create_task_set_list_button"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My tasks"
        app:layout_constraintTop_toBottomOf="@+id/create_task_details_edit_text" />

    <View
        style="@style/Divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/create_task_set_list_button" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/create_task_description_edit_text"
        android:textColor="@color/black"
        style="@style/Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Add description"
        app:layout_constraintTop_toBottomOf="@+id/create_task_set_list_button" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/create_task_set_color_rv"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:clipToPadding="false"
        android:paddingStart="160dp"
        android:paddingEnd="160dp"
        app:layout_constraintTop_toBottomOf="@+id/create_task_description_edit_text" />

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintBottom_toTopOf="@+id/create_task_set_color_rv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>